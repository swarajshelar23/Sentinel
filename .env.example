# Gemini API Key - REQUIRED for AI Chat and Explanation features
# Get your free API key at: https://aistudio.google.com/apikey
# Frontend uses VITE_ prefix, Backend uses regular prefix
VITE_GEMINI_API_KEY=""
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VirusTotal API Key for malware reputation lookups
VIRUSTOTAL_API_KEY=""

# Threat Scoring Weights (Total should ideally be 100, but system normalizes)
WEIGHT_ENTROPY=20
WEIGHT_YARA=30
WEIGHT_VT=25
WEIGHT_AI=25
